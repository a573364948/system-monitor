{
  "commands": [
    {
      "id": "system-status",
      "label": "系统状态",
      "command": "systemctl --user status",
      "description": "查看用户服务状态",
      "category": "system"
    },
    {
      "id": "disk-usage",
      "label": "磁盘使用",
      "command": "df -h",
      "description": "查看磁盘使用情况",
      "category": "system"
    },
    {
      "id": "memory-usage",
      "label": "内存使用",
      "command": "free -h",
      "description": "查看内存使用情况",
      "category": "system"
    },
    {
      "id": "openclaw-logs",
      "label": "OpenClaw 日志",
      "command": "journalctl --user -u openclaw-gateway.service -n 50 --no-pager",
      "description": "查看 OpenClaw 最近日志",
      "category": "openclaw"
    },
    {
      "id": "openviking-logs",
      "label": "OpenViking 日志",
      "command": "journalctl --user -u openviking.service -n 50 --no-pager",
      "description": "查看 OpenViking 最近日志",
      "category": "openviking"
    }
  ]
}
