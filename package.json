{
  "name": "system-monitor",
  "version": "1.0.0",
  "description": "System Monitor - 通用系统监控控制程序",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node test.js",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "build:android": "npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "keywords": [
    "system-monitor",
    "openclaw",
    "android"
  ],
  "author": "deck",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "playwright": "^1.40.0"
  }
}
